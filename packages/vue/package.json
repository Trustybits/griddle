{
  "name": "@griddle/vue",
  "version": "0.1.3",
  "description": "Vue 3 bindings for Griddle — a headless, zero-dependency grid/canvas engine.",
  "keywords": [
    "grid",
    "canvas",
    "layout",
    "drag-and-drop",
    "drag",
    "resize",
    "headless",
    "virtualization",
    "tiles",
    "vue"
  ],
  "homepage": "https://github.com/Trustybits/griddle#readme",
  "bugs": {
    "url": "https://github.com/Trustybits/griddle/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trustybits/griddle.git",
    "directory": "packages/vue"
  },
  "license": "MIT",
  "author": "Trustybits",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "vite build && vue-tsc -p tsconfig.json",
    "test": "node --test test/animation.test.mjs",
    "prepublishOnly": "npm run build && npm test"
  },
  "peerDependencies": {
    "vue": "^3.3.0",
    "@griddle/core": "^0.1.3"
  },
  "devDependencies": {
    "vue": "^3.4.0",
    "@griddle/core": "^0.1.3",
    "vite": "^5.4.0",
    "@vitejs/plugin-vue": "^5.2.0",
    "vue-tsc": "^2.2.0"
  }
}
