{
  "name": "@griddle/react",
  "version": "0.1.1",
  "description": "React bindings for Griddle — a headless, zero-dependency grid/canvas engine.",
  "keywords": [
    "grid",
    "canvas",
    "layout",
    "drag-and-drop",
    "drag",
    "resize",
    "headless",
    "virtualization",
    "tiles",
    "react"
  ],
  "homepage": "https://github.com/Trustybits/griddle#readme",
  "bugs": {
    "url": "https://github.com/Trustybits/griddle/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Trustybits/griddle.git",
    "directory": "packages/react"
  },
  "license": "MIT",
  "author": "Trustybits",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=17",
    "@griddle/core": "^0.1.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "react": "^18.2.0",
    "typescript": "^5.4.0",
    "@griddle/core": "^0.1.0"
  }
}
